# ============================================================
#  Petersen Memories – Beispiel-Konfiguration
#  Kopiere diese Datei nach ".env" und passe die Werte an.
#  cp .env.example .env
# ============================================================

# --- Datenbank ----------------------------------------------
# SQLite ist der einfachste Start. Fuer Produktion kann hier auch
# eine PostgreSQL-/MySQL-URL stehen (dann provider in prisma/schema.prisma anpassen).
DATABASE_URL="file:./dev.db"

# --- Sicherheit ---------------------------------------------
# Geheimer Schluessel zum Signieren der Sitzungs-Cookies.
# Generieren z.B. mit:  openssl rand -hex 32
SESSION_SECRET="bitte-aendern-langer-zufaelliger-string-min-32-zeichen"

# Passwort fuer den Admin-Bereich (/admin).
ADMIN_PASSWORD="bitte-ein-sicheres-passwort-setzen"

# Optionaler Gaeste-Code. Wenn gesetzt, muessen Gaeste den Code
# einmalig eingeben, bevor sie die Seite sehen.
# Leer lassen = die Seite ist fuer alle frei zugaenglich.
GUEST_CODE=""

# --- Uploads ------------------------------------------------
# Verzeichnis, in dem hochgeladene Fotos/Videos gespeichert werden.
UPLOAD_DIR="./uploads"

# Maximale Dateigroesse pro Datei in Megabyte.
MAX_FILE_SIZE_MB="120"

# true  = neue Uploads muessen vom Admin freigegeben werden, bevor sie sichtbar sind
# false = Uploads erscheinen sofort in der Galerie
REQUIRE_APPROVAL="false"

# --- Oeffentliche Werte (im Browser sichtbar) ---------------
# Basis-URL der Seite (Fallback fuer den QR-Code). Im laufenden Betrieb
# erkennt die Seite die echte Adresse automatisch aus der Anfrage.
# Beispiel fuer Betrieb auf einer Server-IP:
#   NEXT_PUBLIC_SITE_URL="http://178.105.143.126:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Namen des Brautpaars (Anzeige im Header & in Texten).
NEXT_PUBLIC_COUPLE_NAMES="Jessica & Leon"

# Hochzeitsdatum (frei formatierbar, z.B. "16. August 2025"). Optional.
NEXT_PUBLIC_WEDDING_DATE=""
